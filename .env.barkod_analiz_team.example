# Safe-to-share integration skeleton for the Barkod Analiz team.
# Keep real secrets in local env files or a secret manager, not in Git history.

# Market Gelsin API
MARKET_GELSIN_API_BASE_URL=http://127.0.0.1:8040
MARKET_GELSIN_INGEST_TOKEN=<strong-random-token>

# Supabase read-model
SUPABASE_URL=https://bqljlyhpkvbeeawedwbm.supabase.co
SUPABASE_DB_HOST=db.bqljlyhpkvbeeawedwbm.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-1-eu-north-1.pooler.supabase.com:5432/postgres?sslmode=require
MARKET_GELSIN_DB_URL=${SUPABASE_DB_URL}

# Firebase scan mirror
MARKET_GELSIN_FIREBASE_CREDENTIALS=/absolute/path/to/barkod-analiz-firebase.json
MARKET_GELSIN_FIREBASE_PROJECT_ID=barkodanaliz-5ed4b
MARKET_GELSIN_FIREBASE_COLLECTION=market_gelsin_barcode_scans
